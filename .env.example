# SMTP Configuration
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=yogesh@binarygrowth.org
SMTP_PASS=your_email_password_here
FROM_NAME=Yogesh

# Scheduler Configuration (GitHub Actions hourly run delay in minutes)
# Delays execution by a random duration between these bounds to simulate natural human sends.
# Max can be up to 55 minutes since GitHub Actions jobs timeout after 6 hours but we want them completed within the hour.
MIN_DELAY_MINUTES=5
MAX_DELAY_MINUTES=45

# File Paths (defaults to current directory if not specified)
LEADS_CSV_PATH=leads.csv
STATE_JSON_PATH=state.json
EMAIL_TEMPLATES_DIR=email-templates
